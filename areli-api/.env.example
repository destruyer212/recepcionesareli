## Copia este archivo como .env y completa valores reales (nunca subas .env al repositorio).

# PostgreSQL — Supabase pooling o cualquier Postgres con esquema areli migrado por Flyway
SUPABASE_DB_URL=jdbc:postgresql://TU_HOST:6543/postgres?sslmode=require&prepareThreshold=0&currentSchema=areli,public
SUPABASE_DB_USER=TU_USUARIO
SUPABASE_DB_PASSWORD=TU_PASSWORD

# Solo si alguna integración del backend llama Supabase REST (opcional para tu caso)
SUPABASE_URL=https://TU_PROYECTO.supabase.co
SUPABASE_REST_URL=https://TU_PROYECTO.supabase.co/rest/v1/
SUPABASE_PUBLISHABLE_KEY=tu_publishable_key

AI_ENABLED=false
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5

# VPS + HTTPS: todos los orígenes del SPA público, separados por coma.
# Ejemplo SPA en https://recepciones.tudominio.com y desarrollo local:
APP_CORS_ALLOWED_ORIGINS=http://localhost:5173,https://recepciones.tudominio.com

PORT=8083

# Producción VPS: aumenta según concurrencia (cada servidor Tomcat tiene su pool).
DB_POOL_MAX_SIZE=10

# Opcional si guardas el token en el menú Configuración (base de datos tiene prioridad).
PERU_API_TOKEN=
