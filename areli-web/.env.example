# Desarrollo: el SPA llama a /api y Vite redirige al JAR Spring.
# Puerto del backend debe coincidir con PORT en areli-api/.env (p. ej. 8083).
VITE_DEV_PROXY_TARGET=http://127.0.0.1:8083

# Si defines VITE_API_BASE_URL se ignora la ruta por defecto /api (ojo: sin proxy si apuntas a otro host).
# VITE_API_BASE_URL=http://127.0.0.1:8083/api

# Producción (npm run build): sin variables en el servidor, el bundle usa rutas relativas `/api`;
# pon Nginx (u otro) con proxy `/api` -> http://127.0.0.1:TU_PUERTO/api
#
# Si el SPA y la API están en dominios distintos, compila así:
# VITE_API_BASE_URL=https://api.tudominio.com/api
